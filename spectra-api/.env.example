# ── ClickHouse Connection ─────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# These are the same credentials you use in db-dashboard.html.

CH_HOST=your-instance.clickhouse.cloud
CH_PORT=8443
CH_DB=default
CH_USER=default
CH_PASSWORD=your_password_here
CH_SSL=true
